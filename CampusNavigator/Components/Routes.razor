@namespace CampusNavigator.Components
@using Microsoft.AspNetCore.Components.Routing

<Router AppAssembly="@typeof(Routes).Assembly">
    <Found Context="routeData">
        <RouteView RouteData="@routeData" DefaultLayout="@typeof(CampusNavigator.ComponentsLayout.MainLayout)" />
    </Found>
    <NotFound>
        <LayoutView Layout="@typeof(CampusNavigator.ComponentsLayout.MainLayout)">
            <p style="color:white;padding:20px">Pagina nu a fost găsită.</p>
        </LayoutView>
    </NotFound>
</Router>
