<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CampusNavigator.Views.SetupPage"
             Title="Configurare profil"
             BackgroundColor="#F5F7FA">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="0">

            <!-- Header -->
            <Label Text="🎓 Campus Navigator"
                   FontSize="26"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   TextColor="#1A1A2E"
                   Margin="0,32,0,4"/>
            <Label Text="Configurează-ți profilul o singură dată"
                   FontSize="14"
                   HorizontalOptions="Center"
                   TextColor="#666"
                   Margin="0,0,0,36"/>

            <!-- Specializare -->
            <Label Text="Specializare" FontAttributes="Bold" TextColor="#1A1A2E" FontSize="14" Margin="0,0,0,6"/>
            <Border StrokeShape="RoundRectangle 10" Stroke="#DDE3EE" Padding="4,0" BackgroundColor="White" Margin="0,0,0,16">
                <Picker x:Name="PickerSpecializare"
                        Title="Alege specializarea"
                        SelectedIndexChanged="OnSpecializareChanged"
                        TextColor="#1A1A2E"
                        TitleColor="#999">
                    <Picker.Items>
                        <x:String>Calculatoare</x:String>
                        <x:String>Automatica</x:String>
                    </Picker.Items>
                </Picker>
            </Border>

            <!-- An -->
            <Label Text="Anul de studiu" FontAttributes="Bold" TextColor="#1A1A2E" FontSize="14" Margin="0,0,0,6"/>
            <Border StrokeShape="RoundRectangle 10" Stroke="#DDE3EE" Padding="4,0" BackgroundColor="White" Margin="0,0,0,16">
                <Picker x:Name="PickerAn"
                        Title="Alege anul"
                        SelectedIndexChanged="OnAnChanged"
                        TextColor="#1A1A2E"
                        TitleColor="#999">
                    <Picker.Items>
                        <x:String>Anul 1</x:String>
                        <x:String>Anul 2</x:String>
                        <x:String>Anul 3</x:String>
                        <x:String>Anul 4</x:String>
                    </Picker.Items>
                </Picker>
            </Border>

            <!-- Limba -->
            <Label Text="Limba de predare" FontAttributes="Bold" TextColor="#1A1A2E" FontSize="14" Margin="0,0,0,6"/>
            <Border StrokeShape="RoundRectangle 10" Stroke="#DDE3EE" Padding="4,0" BackgroundColor="White" Margin="0,0,0,16">
                <Picker x:Name="PickerLimba"
                        Title="Alege limba"
                        SelectedIndexChanged="OnLimbaChanged"
                        TextColor="#1A1A2E"
                        TitleColor="#999">
                    <Picker.Items>
                        <x:String>Română</x:String>
                        <x:String>Engleză</x:String>
                    </Picker.Items>
                </Picker>
            </Border>

            <!-- Grupa -->
            <Label Text="Grupa" FontAttributes="Bold" TextColor="#1A1A2E" FontSize="14" Margin="0,0,0,6"/>
            <Border StrokeShape="RoundRectangle 10" Stroke="#DDE3EE" Padding="4,0" BackgroundColor="White" Margin="0,0,0,16">
                <Picker x:Name="PickerGrupa"
                        Title="Alege grupa"
                        SelectedIndexChanged="OnGrupaChanged"
                        TextColor="#1A1A2E"
                        TitleColor="#999"
                        IsEnabled="False"/>
            </Border>

            <!-- Semigrupa -->
            <Label Text="Semigrupa" FontAttributes="Bold" TextColor="#1A1A2E" FontSize="14" Margin="0,0,0,6"/>
            <HorizontalStackLayout Spacing="12" Margin="0,0,0,36">
                <Border x:Name="BtnSg1"
                        StrokeShape="RoundRectangle 10"
                        Stroke="#3B6FD4"
                        BackgroundColor="#3B6FD4"
                        Padding="0"
                        HeightRequest="48"
                        WidthRequest="120">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnSemigrupa1Tapped"/>
                    </Border.GestureRecognizers>
                    <Label Text="Semigrupa 1"
                           TextColor="White"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"
                           FontSize="14"/>
                </Border>
                <Border x:Name="BtnSg2"
                        StrokeShape="RoundRectangle 10"
                        Stroke="#DDE3EE"
                        BackgroundColor="White"
                        Padding="0"
                        HeightRequest="48"
                        WidthRequest="120">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnSemigrupa2Tapped"/>
                    </Border.GestureRecognizers>
                    <Label Text="Semigrupa 2"
                           TextColor="#1A1A2E"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"
                           FontSize="14"/>
                </Border>
            </HorizontalStackLayout>

            <!-- Buton salvare -->
            <Button x:Name="BtnSave"
                    Text="Salvează și continuă →"
                    Clicked="OnSaveClicked"
                    BackgroundColor="#3B6FD4"
                    TextColor="White"
                    FontAttributes="Bold"
                    FontSize="16"
                    HeightRequest="52"
                    CornerRadius="12"
                    IsEnabled="False"
                    Margin="0,0,0,32"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
