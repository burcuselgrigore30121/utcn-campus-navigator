<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:CampusNavigator.Models"
             x:Class="CampusNavigator.Views.OrarPage"
             Title="Orar"
             BackgroundColor="#F5F7FA">

    <Shell.TitleView>
        <HorizontalStackLayout VerticalOptions="Center" Spacing="8">
            <Label x:Name="LblTitle" Text="Orar" FontAttributes="Bold" FontSize="18" TextColor="#1A1A2E" VerticalOptions="Center"/>
        </HorizontalStackLayout>
    </Shell.TitleView>

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- Header: info saptamana + toggle para/impara -->
        <Border Grid.Row="0" BackgroundColor="White" StrokeShape="RoundRectangle 0,0,16,16"
                Stroke="Transparent" Padding="16,12">
            <Grid ColumnDefinitions="*,Auto">
                <VerticalStackLayout Grid.Column="0" Spacing="2">
                    <Label x:Name="LblGrupa" FontSize="13" TextColor="#666"/>
                    <Label x:Name="LblSaptamana" FontSize="15" FontAttributes="Bold" TextColor="#1A1A2E"/>
                </VerticalStackLayout>
                <!-- Toggle para/impara -->
                <Border Grid.Column="1" StrokeShape="RoundRectangle 20" BackgroundColor="#EEF2FF"
                        Stroke="Transparent" Padding="4">
                    <HorizontalStackLayout Spacing="2">
                        <Border x:Name="BtnImpara" StrokeShape="RoundRectangle 16"
                                BackgroundColor="#3B6FD4" Stroke="Transparent" Padding="10,6">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnImparaTapped"/>
                            </Border.GestureRecognizers>
                            <Label Text="Impară" TextColor="White" FontSize="12" FontAttributes="Bold"/>
                        </Border>
                        <Border x:Name="BtnPara" StrokeShape="RoundRectangle 16"
                                BackgroundColor="Transparent" Stroke="Transparent" Padding="10,6">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnParaTapped"/>
                            </Border.GestureRecognizers>
                            <Label Text="Pară" TextColor="#3B6FD4" FontSize="12"/>
                        </Border>
                    </HorizontalStackLayout>
                </Border>
            </Grid>
        </Border>

        <!-- Tabs zile -->
        <ScrollView Grid.Row="1" Orientation="Horizontal" HorizontalScrollBarVisibility="Never"
                    Margin="0,8,0,0">
            <HorizontalStackLayout x:Name="ZileTabs" Padding="12,0" Spacing="8">
                <!-- generate din code-behind -->
            </HorizontalStackLayout>
        </ScrollView>

        <!-- Lista activitati -->
        <CollectionView x:Name="OrarList"
                        Grid.Row="2"
                        Margin="0,8,0,0">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:ScheduleEntry">
                    <Border Margin="16,4" Padding="0" StrokeShape="RoundRectangle 14"
                            Stroke="Transparent" BackgroundColor="White">
                        <Grid ColumnDefinitions="6,*" >
                            <!-- bara colorata stanga dupa tip -->
                            <BoxView Grid.Column="0"
                                     x:Name="TipBar"
                                     CornerRadius="6,0,0,6"
                                     BackgroundColor="{Binding Tip, Converter={StaticResource TipColorConverter}}"/>
                            <Grid Grid.Column="1" Padding="14,12" RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="*,Auto">
                                <!-- Materie -->
                                <Label Grid.Row="0" Grid.Column="0"
                                       Text="{Binding Materie}"
                                       FontAttributes="Bold"
                                       FontSize="15"
                                       TextColor="#1A1A2E"
                                       LineBreakMode="TailTruncation"/>
                                <!-- Ora -->
                                <Label Grid.Row="0" Grid.Column="1"
                                       Text="{Binding Slot}"
                                       FontSize="13"
                                       TextColor="#888"
                                       VerticalOptions="Center"/>
                                <!-- Tip activitate -->
                                <Label Grid.Row="1" Grid.Column="0"
                                       Text="{Binding Tip}"
                                       FontSize="12"
                                       TextColor="#3B6FD4"
                                       IsVisible="{Binding Tip, Converter={StaticResource NotNullConverter}}"/>
                                <!-- Sala + buton maps -->
                                <HorizontalStackLayout Grid.Row="2" Grid.ColumnSpan="2" Spacing="8" Margin="0,6,0,0">
                                    <Label Text="📍"
                                           FontSize="14"
                                           VerticalOptions="Center"
                                           IsVisible="{Binding Sala, Converter={StaticResource NotNullConverter}}"/>
                                    <Label Text="{Binding Sala}"
                                           FontSize="14"
                                           TextColor="#444"
                                           VerticalOptions="Center"
                                           IsVisible="{Binding Sala, Converter={StaticResource NotNullConverter}}"/>
                                    <!-- Buton Google Maps -->
                                    <Border StrokeShape="RoundRectangle 8"
                                            BackgroundColor="#EEF2FF"
                                            Stroke="Transparent"
                                            Padding="8,4"
                                            IsVisible="{Binding MapsUrl, Converter={StaticResource NotNullConverter}}">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer
                                                CommandParameter="{Binding MapsUrl}"
                                                Tapped="OnMapsButtonTapped"/>
                                        </Border.GestureRecognizers>
                                        <Label Text="🗺 Maps" FontSize="12" TextColor="#3B6FD4"/>
                                    </Border>
                                </HorizontalStackLayout>
                            </Grid>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>

            <CollectionView.EmptyView>
                <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Padding="32">
                    <Label Text="😴" FontSize="48" HorizontalOptions="Center"/>
                    <Label Text="Nicio activitate în ziua aceasta"
                           FontSize="16" TextColor="#999" HorizontalOptions="Center" Margin="0,8,0,0"/>
                </VerticalStackLayout>
            </CollectionView.EmptyView>
        </CollectionView>

    </Grid>
</ContentPage>
